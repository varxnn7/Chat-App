rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Chats ──────────────────────────────────────────────────────────
    match /chats/{chatId} {
      // Create: authenticated user must include themselves in participants
      allow create: if isAuthenticated() &&
                    request.auth.uid in request.resource.data.participants;

      // Read / delete: must be a participant
      allow read, delete: if isAuthenticated() &&
                          request.auth.uid in resource.data.participants;

      // Update (e.g., merge participants): must be a participant
      allow update: if isAuthenticated() &&
                    request.auth.uid in resource.data.participants;

      // ── Messages ─────────────────────────────────────────────────────
      match /messages/{messageId} {
        // Helper: verify the caller is a participant of the parent chat
        function isParticipant() {
          return isAuthenticated() &&
                 request.auth.uid in
                   get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }

        // Read: any participant can read messages
        allow read: if isParticipant();

        // Create: any participant can send new messages
        allow create: if isParticipant();

        // Update rules – enforce delete semantics
        allow update: if isParticipant() && (
          // ① "Delete for me" / "Undo delete for me"
          //    Only the deletedFor field changes. Caller can add or remove their own UID.
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor'])
          )
          ||
          // ② "Delete for everyone" – only the original sender can do this
          (
            request.auth.uid == resource.data.sender &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['deletedForEveryone', 'text', 'imageUrl', 'fileName', 'fileType']) &&
            request.resource.data.deletedForEveryone == true
          )
          ||
          // ③ "Seen" status – receiver can mark messages as seen
          (
            request.auth.uid == resource.data.receiver &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seen', 'seenAt']) &&
            request.resource.data.seen == true
          )
        );

        // Delete: nobody can physically delete message docs (soft delete only)
        allow delete: if false;
      }
    }

    // ── Users ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;

      // ClearedChats subcollection – only the owner can read/write
      match /clearedChats/{chatId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ── Fallback – deny everything else ───────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
